{
  "name": "@cinatra-ai/blog-wordpress-publish-agent",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "description": "Creates a WordPress draft from a Cinatra blog post: starts the draft creation job, polls blog_project_get until ready, then pauses for HITL operator confirmation. On reject, deletes the draft from WordPress.",
  "type": "module",
  "files": [
    "cinatra",
    "skills",
    "src"
  ],
  "peerDependencies": {
    "@cinatra-ai/sdk-extensions": "*",
    "@cinatra-ai/sdk-ui": "*",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    },
    "@cinatra-ai/sdk-ui": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "react": "^19.0.0"
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "agent",
    "displayName": "Blog WordPress Publish Agent",
    "dependencies": [
      {
        "packageName": "@cinatra-ai/wordpress-mcp-connector",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "semver-range",
          "range": "^0.1.4"
        },
        "requirement": "required",
        "kind": "connector"
      }
    ],
    "consumes": [
      {
        "primitive": "blog_post_publish_wordpress_start",
        "requirement": "required"
      },
      {
        "primitive": "blog_post_publish_wordpress_delete",
        "requirement": "required"
      },
      {
        "primitive": "blog_post_publish_wordpress_status",
        "requirement": "required"
      },
      {
        "primitive": "blog_project_get",
        "requirement": "required"
      }
    ],
    "fieldRenderers": [
      {
        "id": "@cinatra-ai/blog-wordpress-publish-agent:draft-confirm",
        "kind": "wordpress-draft-confirm",
        "priority": 90,
        "midRunHitl": true,
        "component": {
          "entry": "./src/renderers/draft-confirm.tsx",
          "propsApiVersion": 1
        }
      }
    ],
    "packageType": "agent",
    "manifestVersion": 1,
    "sourceTemplateId": "blog-wordpress-publish-agent-flow",
    "sourceVersionId": "d7d9f3a9-a6fa-4f18-8879-375c833b3e3e",
    "sourceVersionNumber": 1,
    "riskLevel": "low",
    "hasApprovalGates": false,
    "toolAccess": [],
    "ownerOrgId": null
  }
}
